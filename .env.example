# Copy this file to ".env" and fill in real values. NEVER commit ".env".

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# ---- Database ----
# DB_ENGINE options: sqlite (default) | azure | postgres
#
# Azure SQL (what this project uses):
#   DB_ENGINE=azure
#   DB_NAME=hr_recruitment
#   DB_USER=<sql admin login>
#   DB_PASSWORD=<sql admin password>
#   DB_HOST=<yourserver>.database.windows.net
#   DB_PORT=1433
#
# Postgres:
#   DB_ENGINE=postgres  (+ DB_NAME/DB_USER/DB_PASSWORD/DB_HOST/DB_PORT)

DB_ENGINE=sqlite
DB_NAME=hr_recruitment
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=1433
