DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Set DB_ENGINE=postgres to switch off SQLite (Azure SQL: point these at an
# ODBC-based Django backend such as mssql-django with the same var names).
DB_ENGINE=sqlite
DB_NAME=hr_recruitment
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Path to the Central Repository workbook used by import_candidates.
CENTRAL_REPOSITORY_XLSX=../Central Repository.xlsx

# SharePoint sync (recruitment/sync_sharepoint.py)
SHAREPOINT_SITE_URL=
SHAREPOINT_USERNAME=
SHAREPOINT_PASSWORD=
SHAREPOINT_FILE_URL=
